{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd erp-frontend && npm install",
  "buildCommand": "cd erp-frontend && npm run build",
  "outputDirectory": "erp-frontend/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
